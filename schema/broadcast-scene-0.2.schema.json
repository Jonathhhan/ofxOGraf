{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ofxograf.dev/schema/broadcast-scene-0.2.schema.json",
  "title": "Broadcast Scene 0.2",
  "type": "object",
  "required": ["format", "version", "composition", "layers"],
  "properties": {
    "format": { "const": "broadcast-scene" },
    "version": { "pattern": "^0\\.[2-9]|^[1-9]" },
    "source": { "type": "object" },
    "composition": { "$ref": "#/$defs/compositionInfo" },
    "layers": { "type": "array", "items": { "$ref": "#/$defs/layer" } },
    "compositions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "composition", "layers"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "composition": { "$ref": "#/$defs/compositionInfo" },
          "layers": { "type": "array", "items": { "$ref": "#/$defs/layer" } }
        }
      }
    },
    "assets": {
      "type": "object",
      "properties": {
        "fonts": { "type": "array", "items": { "$ref": "#/$defs/fontAsset" } },
        "images": { "type": "array", "items": { "$ref": "#/$defs/imageAsset" } }
      }
    },
    "controls": { "type": "array", "items": { "$ref": "#/$defs/control" } },
    "report": { "type": "object" }
  },
  "$defs": {
    "vector": { "type": "array", "items": { "type": "number" }, "minItems": 2, "maxItems": 4 },
    "compositionInfo": {
      "type": "object",
      "required": ["width", "height", "duration", "frameRate"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "duration": { "type": "number", "minimum": 0 },
        "frameRate": { "type": "number", "exclusiveMinimum": 0 },
        "pixelAspect": { "type": "number", "exclusiveMinimum": 0 },
        "displayStartTime": { "type": "number" },
        "backgroundColor": { "$ref": "#/$defs/vector" }
      }
    },
    "sample": {
      "type": "object",
      "required": ["time", "value"],
      "properties": { "time": { "type": "number" }, "value": {} }
    },
    "keyframe": {
      "type": "object",
      "required": ["time", "value"],
      "properties": {
        "time": { "type": "number" },
        "value": {},
        "inInterpolation": { "enum": ["linear", "hold", "bezier"] },
        "outInterpolation": { "enum": ["linear", "hold", "bezier"] },
        "inEase": { "type": "array" },
        "outEase": { "type": "array" },
        "inSpatialTangent": { "$ref": "#/$defs/vector" },
        "outSpatialTangent": { "$ref": "#/$defs/vector" }
      }
    },
    "property": {
      "type": "object",
      "required": ["name", "matchName"],
      "properties": {
        "name": { "type": "string" },
        "matchName": { "type": "string" },
        "value": {},
        "expression": { "type": "string" },
        "samples": { "type": "array", "items": { "$ref": "#/$defs/sample" } },
        "keyframes": { "type": "array", "items": { "$ref": "#/$defs/keyframe" } },
        "children": { "type": "array", "items": { "$ref": "#/$defs/property" } },
        "controlId": { "type": "string" },
        "maskMode": { "type": "string" },
        "inverted": { "type": "boolean" }
      }
    },
    "fallback": {
      "type": "object",
      "required": ["enabled", "filePattern"],
      "properties": {
        "enabled": { "type": "boolean" },
        "filePattern": { "type": "string" },
        "files": { "type": "array", "items": { "type": "string" } },
        "frameRate": { "type": "number", "exclusiveMinimum": 0 },
        "startFrame": { "type": "integer" },
        "reasons": { "type": "array", "items": { "type": "string" } }
      }
    },
    "layer": {
      "type": "object",
      "required": ["index", "name", "type", "inPoint", "outPoint"],
      "properties": {
        "index": { "type": "integer", "minimum": 1 },
        "name": { "type": "string" },
        "type": { "enum": ["text", "shape", "image", "solid", "precomp", "camera", "light", "null", "baked", "unknown"] },
        "enabled": { "type": "boolean" },
        "inPoint": { "type": "number" },
        "outPoint": { "type": "number" },
        "parentIndex": { "type": ["integer", "null"] },
        "threeDLayer": { "type": "boolean" },
        "trackMatteType": { "type": "string" },
        "transform": { "$ref": "#/$defs/property" },
        "text": { "$ref": "#/$defs/property" },
        "contents": { "$ref": "#/$defs/property" },
        "masks": { "$ref": "#/$defs/property" },
        "effects": { "$ref": "#/$defs/property" },
        "essentialProperties": { "$ref": "#/$defs/property" },
        "fallback": { "$ref": "#/$defs/fallback" }
      }
    },
    "fontAsset": {
      "type": "object",
      "required": ["postScriptName", "file"],
      "properties": {
        "postScriptName": { "type": "string" }, "family": { "type": "string" },
        "style": { "type": "string" }, "file": { "type": "string" }
      }
    },
    "imageAsset": {
      "type": "object",
      "required": ["id", "file"],
      "properties": { "id": { "type": "string" }, "file": { "type": "string" }, "originalFile": { "type": "string" } }
    },
    "control": {
      "type": "object",
      "required": ["id", "name", "type"],
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string" }, "type": { "type": "string" },
        "default": {}, "source": { "type": "string" }, "controllerIndex": { "type": "integer" },
        "matchName": { "type": "string" }
      }
    }
  }
}
